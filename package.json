  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-istanbul": "^4.1.6",
    "eslint": "^10.1.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.6",
    "wrangler": "^4.90.0"
  }
